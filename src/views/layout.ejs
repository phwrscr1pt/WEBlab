<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>ThaiMart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof extraCss !== 'undefined') { %>
    <link rel="stylesheet" href="<%= extraCss %>">
  <% } %>
</head>
<body>
  <header class="header">
    <div class="container header-content">
      <a href="/" class="logo">
        <span class="logo-icon">🛒</span>
        <span class="logo-text">ThaiMart</span>
      </a>
      <nav class="nav">
        <a href="/" class="nav-link">หน้าแรก</a>
        <a href="/lab01" class="nav-link">API Tester</a>
        <a href="/lab02" class="nav-link">สมาชิก</a>
        <a href="/lab04" class="nav-link">ผู้ขาย</a>
        <a href="/lab05" class="nav-link">พนักงาน</a>
        <a href="/lab07" class="nav-link">ค้นหา</a>
        <a href="/lab09" class="nav-link">รีวิว</a>
      </nav>
      <div class="header-slogan">ช้อปสนุก ส่งไว ทั่วไทย</div>
    </div>
  </header>

  <main class="main">
    <%- body %>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="logo-icon">🛒</span>
          <span>ThaiMart</span>
        </div>
        <p class="footer-text">© 2569 ThaiMart Co., Ltd. สงวนลิขสิทธิ์</p>
        <p class="footer-text">บริษัท ไทยมาร์ท จำกัด | 123 ถนนสุขุมวิท กรุงเทพฯ 10110</p>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
  <% if (typeof extraJs !== 'undefined') { %>
    <script src="<%= extraJs %>"></script>
  <% } %>
</body>
</html>
