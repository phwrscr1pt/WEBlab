<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ThaiMart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .sql-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    @media (max-width: 1000px) {
      .sql-layout { grid-template-columns: 1fr; }
    }
    .sql-editor {
      background: #1e1e1e;
      border-radius: 12px;
      overflow: hidden;
    }
    .editor-header {
      background: #2d2d2d;
      padding: 0.75rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #404040;
    }
    .editor-title {
      color: #e5e7eb;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .sql-textarea {
      width: 100%;
      min-height: 150px;
      background: #1e1e1e;
      color: #d4d4d4;
      border: none;
      padding: 1rem;
      font-family: 'Fira Code', monospace;
      font-size: 0.9rem;
      resize: vertical;
      outline: none;
    }
    .sql-textarea::placeholder {
      color: #6b7280;
    }
    .editor-footer {
      background: #2d2d2d;
      padding: 0.75rem 1rem;
      display: flex;
      gap: 0.5rem;
      border-top: 1px solid #404040;
    }
    .btn-run {
      background: #22c55e;
      color: white;
      border: none;
      padding: 0.5rem 1.5rem;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-run:hover { background: #16a34a; }
    .btn-reset {
      background: #ef4444;
      color: white;
      border: none;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      cursor: pointer;
    }
    .btn-reset:hover { background: #dc2626; }
    .result-panel {
      background: white;
      border-radius: 12px;
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .result-header {
      background: var(--background);
      padding: 0.75rem 1rem;
      font-weight: 600;
      border-bottom: 1px solid var(--border);
    }
    .result-body {
      padding: 1rem;
      max-height: 400px;
      overflow: auto;
    }
    .query-display {
      background: #f1f5f9;
      padding: 0.75rem 1rem;
      border-radius: 6px;
      font-family: 'Fira Code', monospace;
      font-size: 0.85rem;
      margin-bottom: 1rem;
      color: #1e3a5f;
    }
    .schema-box {
      background: #f0fdf4;
      border: 1px solid #22c55e;
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1.5rem;
    }
    .schema-box h4 {
      color: #166534;
      margin-bottom: 0.5rem;
    }
    .schema-cols {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .schema-col {
      background: #dcfce7;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-family: 'Fira Code', monospace;
      font-size: 0.8rem;
      color: #166534;
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-content">
      <a href="/" class="logo">
        <span class="logo-icon">🛒</span>
        <span class="logo-text">ThaiMart</span>
      </a>
      <nav class="nav">
        <a href="/" class="nav-link">หน้าแรก</a>
        <a href="/lab03" class="nav-link active">SQL Playground</a>
      </nav>
      <div class="header-slogan">Internal Tools</div>
    </div>
  </header>

  <div class="page-header">
    <div class="container">
      <h1 class="page-title">SQL Playground</h1>
      <p class="page-subtitle">พิมพ์คำสั่ง SQL ด้วยตัวเอง</p>
    </div>
  </div>

  <main class="main">
    <div class="container page-content">

      <!-- Schema Info -->
      <div class="schema-box">
        <h4>📋 ตาราง: playground_products</h4>
        <div class="schema-cols">
          <span class="schema-col">id (SERIAL)</span>
          <span class="schema-col">name (VARCHAR)</span>
          <span class="schema-col">price (DECIMAL)</span>
          <span class="schema-col">stock (INTEGER)</span>
          <span class="schema-col">category (VARCHAR)</span>
        </div>
      </div>

      <div class="sql-layout">
        <!-- Left: Editor -->
        <div>
          <!-- SQL Editor -->
          <form action="/lab03/execute" method="POST">
            <div class="sql-editor">
              <div class="editor-header">
                <span class="editor-title">⌨️ พิมพ์คำสั่ง SQL ที่นี่</span>
              </div>
              <textarea
                name="sql"
                class="sql-textarea"
                placeholder="SELECT * FROM playground_products;"
                spellcheck="false"
              ><%= query || '' %></textarea>
              <div class="editor-footer">
                <button type="submit" class="btn-run">
                  ▶ Run
                </button>
                <button type="button" class="btn-reset" onclick="document.getElementById('resetForm').submit()">
                  🔄 Reset Table
                </button>
              </div>
            </div>
          </form>
          <form id="resetForm" action="/lab03/reset" method="POST" style="display:none;"></form>

          <!-- Query Result -->
          <% if (query) { %>
            <div class="result-panel mt-2">
              <div class="result-header">📤 ผลลัพธ์</div>
              <div class="result-body">
                <div class="query-display"><%= query %></div>

                <% if (error) { %>
                  <div class="alert alert-danger"><%= error %></div>
                <% } else if (success) { %>
                  <div class="alert alert-success"><%= success %></div>
                <% } else if (result && result.length > 0) { %>
                  <div class="table-container">
                    <table class="table">
                      <thead>
                        <tr>
                          <% Object.keys(result[0]).forEach(key => { %>
                            <th><%= key %></th>
                          <% }) %>
                        </tr>
                      </thead>
                      <tbody>
                        <% result.forEach(row => { %>
                          <tr>
                            <% Object.values(row).forEach(val => { %>
                              <td><%= val %></td>
                            <% }) %>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                  <p class="text-muted mt-1" style="font-size: 0.85rem;"><%= result.length %> แถว</p>
                <% } else { %>
                  <p class="text-muted">ไม่มีข้อมูลที่แสดง</p>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Right: Current Table Data -->
        <div>
          <div class="result-panel">
            <div class="result-header">📊 ข้อมูลปัจจุบันในตาราง (<%= products.length %> แถว)</div>
            <div class="result-body">
              <% if (products.length > 0) { %>
                <div class="table-container">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>id</th>
                        <th>name</th>
                        <th>price</th>
                        <th>stock</th>
                        <th>category</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% products.forEach(p => { %>
                        <tr>
                          <td><%= p.id %></td>
                          <td><%= p.name %></td>
                          <td><%= p.price %></td>
                          <td><%= p.stock %></td>
                          <td><%= p.category %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <p class="text-muted text-center">ไม่มีข้อมูล - กด Reset Table เพื่อเริ่มใหม่</p>
              <% } %>
            </div>
          </div>

          <!-- Allowed Commands -->
          <div class="card mt-2">
            <div class="card-header">✅ คำสั่งที่อนุญาต</div>
            <div class="card-body">
              <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">
                <strong style="color: var(--success);">SELECT</strong> - ดึงข้อมูล
              </p>
              <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">
                <strong style="color: var(--info);">INSERT</strong> - เพิ่มข้อมูล
              </p>
              <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">
                <strong style="color: var(--warning);">UPDATE</strong> - แก้ไขข้อมูล
              </p>
              <p style="font-size: 0.9rem; margin-bottom: 0.5rem;">
                <strong style="color: var(--danger);">DELETE</strong> - ลบข้อมูล
              </p>
              <hr style="margin: 1rem 0;">
              <p style="font-size: 0.85rem; color: var(--text-muted);">
                ❌ ไม่อนุญาต: DROP, TRUNCATE, ALTER, CREATE
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p class="footer-text">© 2569 ThaiMart Internal Tools</p>
      </div>
    </div>
  </footer>

</body>
</html>
