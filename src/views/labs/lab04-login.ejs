<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ThaiMart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .seller-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--primary-light);
      color: var(--primary-dark);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-content">
      <a href="/" class="logo">
        <span class="logo-icon">🛒</span>
        <span class="logo-text">ThaiMart</span>
      </a>
      <nav class="nav">
        <a href="/" class="nav-link">หน้าแรก</a>
        <a href="/lab04" class="nav-link active">Seller Portal</a>
      </nav>
      <span class="seller-badge">🏪 Seller Center</span>
    </div>
  </header>

  <main class="main">
    <div class="container page-content">
      <div class="login-container">
        <div class="login-card">
          <div class="text-center mb-3">
            <span style="font-size: 3rem;">🏪</span>
            <h2 class="login-title">Seller Portal</h2>
            <p class="text-muted">เข้าสู่ระบบสำหรับผู้ขาย ThaiMart</p>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form action="/lab04/login" method="POST">
            <div class="form-group">
              <label class="form-label">ชื่อผู้ใช้</label>
              <input type="text" name="username" class="form-input" placeholder="กรอกชื่อผู้ใช้" required>
            </div>

            <div class="form-group">
              <label class="form-label">รหัสผ่าน</label>
              <input type="password" name="password" class="form-input" placeholder="กรอกรหัสผ่าน" required>
            </div>

            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">เข้าสู่ระบบ</button>
          </form>

          <div class="text-center mt-3">
            <a href="#" class="text-muted" style="font-size: 0.85rem;">ลืมรหัสผ่าน?</a>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body text-center">
            <p class="text-muted" style="font-size: 0.85rem;">
              ยังไม่ได้เป็นผู้ขาย? <a href="#" style="color: var(--primary);">สมัครเป็นผู้ขาย</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p class="footer-text">© 2569 ThaiMart Seller Center</p>
      </div>
    </div>
  </footer>
</body>
</html>
