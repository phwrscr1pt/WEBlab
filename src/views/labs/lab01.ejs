<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ThaiMart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .command-card {
      background: #1e1e1e;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .command-header {
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid #333;
    }
    .method-badge {
      font-family: 'Fira Code', monospace;
      font-weight: 600;
      font-size: 0.9rem;
      padding: 0.4rem 0.8rem;
      border-radius: 6px;
      min-width: 70px;
      text-align: center;
    }
    .method-get { background: #22c55e20; color: #22c55e; }
    .method-post { background: #3b82f620; color: #3b82f6; }
    .method-put { background: #f59e0b20; color: #f59e0b; }
    .method-delete { background: #ef444420; color: #ef4444; }
    .command-desc {
      color: #9ca3af;
      font-size: 0.9rem;
    }
    .command-body {
      padding: 1.5rem;
    }
    .command-code {
      background: #0d0d0d;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      font-family: 'Fira Code', monospace;
      font-size: 0.85rem;
      color: #e5e7eb;
      overflow-x: auto;
      position: relative;
    }
    .command-code .prompt { color: #22c55e; }
    .command-code .flag { color: #60a5fa; }
    .command-code .url { color: #fbbf24; }
    .command-code .string { color: #f472b6; }
    .copy-btn {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      background: #374151;
      border: none;
      color: #9ca3af;
      padding: 0.4rem 0.8rem;
      border-radius: 4px;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .copy-btn:hover {
      background: #4b5563;
      color: #fff;
    }
    .intro-box {
      background: linear-gradient(135deg, var(--secondary) 0%, #2d4a6f 100%);
      border-radius: 12px;
      padding: 2rem;
      color: white;
      margin-bottom: 2rem;
    }
    .intro-box h2 {
      margin-bottom: 0.5rem;
    }
    .intro-box p {
      opacity: 0.9;
      margin-bottom: 1rem;
    }
    .intro-box code {
      background: rgba(255,255,255,0.15);
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 0.9rem;
    }
    .methods-table {
      background: white;
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    .methods-table h3 {
      margin-bottom: 1rem;
      color: var(--secondary);
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-content">
      <a href="/" class="logo">
        <span class="logo-icon">🛒</span>
        <span class="logo-text">ThaiMart</span>
      </a>
      <nav class="nav">
        <a href="/" class="nav-link">หน้าแรก</a>
        <a href="/lab01" class="nav-link active">API Tester</a>
      </nav>
      <div class="header-slogan">Developer Portal</div>
    </div>
  </header>

  <div class="page-header">
    <div class="container">
      <h1 class="page-title">API Tester</h1>
      <p class="page-subtitle">ทดสอบ HTTP Methods ผ่าน Terminal</p>
    </div>
  </div>

  <main class="main">
    <div class="container page-content">

      <!-- Introduction -->
      <div class="intro-box">
        <h2>🖥️ ใช้ Terminal ของคุณ</h2>
        <p>Lab นี้ต้องพิมพ์คำสั่ง <code>curl</code> ใน Terminal ด้วยตัวเอง ไม่มีปุ่มให้กด!</p>
        <p>เปิด Terminal (Command Prompt, PowerShell, หรือ Terminal) แล้วพิมพ์คำสั่งด้านล่าง</p>
      </div>

      <!-- Methods Reference -->
      <div class="methods-table">
        <h3>📚 HTTP Methods Reference</h3>
        <table class="table">
          <thead>
            <tr>
              <th>Method</th>
              <th>การใช้งาน</th>
              <th>ตัวอย่าง</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="method-badge method-get">GET</span></td>
              <td>ดึงข้อมูล (Read)</td>
              <td>ดูรายการสินค้า, ดูโปรไฟล์</td>
            </tr>
            <tr>
              <td><span class="method-badge method-post">POST</span></td>
              <td>สร้างข้อมูลใหม่ (Create)</td>
              <td>สมัครสมาชิก, โพสต์ความคิดเห็น</td>
            </tr>
            <tr>
              <td><span class="method-badge method-put">PUT</span></td>
              <td>อัปเดตข้อมูล (Update)</td>
              <td>แก้ไขโปรไฟล์, อัปเดตสินค้า</td>
            </tr>
            <tr>
              <td><span class="method-badge method-delete">DELETE</span></td>
              <td>ลบข้อมูล (Delete)</td>
              <td>ลบสินค้า, ลบความคิดเห็น</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- GET Command -->
      <div class="command-card">
        <div class="command-header">
          <span class="method-badge method-get">GET</span>
          <span class="command-desc">ดึงข้อมูลจาก API</span>
        </div>
        <div class="command-body">
          <div class="command-code">
            <button class="copy-btn" onclick="copyCommand(this)">Copy</button>
            <span class="prompt">$</span> curl <span class="url">http://10.10.61.87/lab01/api/test</span>
          </div>
        </div>
      </div>

      <!-- POST Command -->
      <div class="command-card">
        <div class="command-header">
          <span class="method-badge method-post">POST</span>
          <span class="command-desc">ส่งข้อมูลใหม่ไปยัง API</span>
        </div>
        <div class="command-body">
          <div class="command-code">
            <button class="copy-btn" onclick="copyCommand(this)">Copy</button>
<span class="prompt">$</span> curl <span class="flag">-X POST</span> <span class="url">http://10.10.61.87/lab01/api/test</span> \
     <span class="flag">-H</span> <span class="string">"Content-Type: application/json"</span> \
     <span class="flag">-d</span> <span class="string">'{"name":"test","email":"test@example.com"}'</span>
          </div>
        </div>
      </div>

      <!-- PUT Command -->
      <div class="command-card">
        <div class="command-header">
          <span class="method-badge method-put">PUT</span>
          <span class="command-desc">อัปเดตข้อมูลที่มีอยู่</span>
        </div>
        <div class="command-body">
          <div class="command-code">
            <button class="copy-btn" onclick="copyCommand(this)">Copy</button>
<span class="prompt">$</span> curl <span class="flag">-X PUT</span> <span class="url">http://10.10.61.87/lab01/api/test</span> \
     <span class="flag">-H</span> <span class="string">"Content-Type: application/json"</span> \
     <span class="flag">-d</span> <span class="string">'{"id":1,"name":"updated"}'</span>
          </div>
        </div>
      </div>

      <!-- DELETE Command -->
      <div class="command-card">
        <div class="command-header">
          <span class="method-badge method-delete">DELETE</span>
          <span class="command-desc">ลบข้อมูล</span>
        </div>
        <div class="command-body">
          <div class="command-code">
            <button class="copy-btn" onclick="copyCommand(this)">Copy</button>
<span class="prompt">$</span> curl <span class="flag">-X DELETE</span> <span class="url">"http://10.10.61.87/lab01/api/test?id=1"</span>
          </div>
        </div>
      </div>

      <!-- Expected Output -->
      <div class="card">
        <div class="card-header">📤 ตัวอย่าง Response ที่จะได้รับ</div>
        <div class="card-body">
          <div class="command-code" style="position: static;">
<pre style="margin: 0; color: #e5e7eb;">{
  "method": "POST",
  "path": "/api/test",
  "headers": {
    "content-type": "application/json",
    "user-agent": "curl/7.68.0",
    "host": "10.10.61.87"
  },
  "query": {},
  "body": {
    "name": "test",
    "email": "test@example.com"
  },
  "timestamp": "2026-04-18T12:00:00.000Z"
}</pre>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p class="footer-text">© 2569 ThaiMart Developer Portal</p>
      </div>
    </div>
  </footer>

  <script>
    function copyCommand(btn) {
      const codeBlock = btn.parentElement;
      const text = codeBlock.innerText.replace('Copy', '').replace('$', '').trim();
      navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    }
  </script>
</body>
</html>
